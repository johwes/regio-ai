# Regio-AI agent application — Gradio + LangChain + geospatial stack
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
        gdal-bin libgdal-dev gcc g++ git curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py tools.py ./

# Configuration — override via Deployment env vars or Secret
ENV LITELLM_ENDPOINT=https://litellm-prod.apps.maas.redhatworkshops.io/v1
ENV LITELLM_API_KEY=""
ENV LLM_MODEL=qwen3-14b
ENV PRITHVI_URL=http://prithvi-water-predictor.jwesterl.svc.cluster.local:8080/v2/models/prithvi-water/infer
ENV PORT=7860

EXPOSE 7860

# Non-root UID 1001 — required for OpenShift's restricted SCC
RUN useradd -u 1001 -r -g 0 -d /app -s /sbin/nologin appuser \
    && chown -R 1001:0 /app \
    && chmod -R g=u /app
USER 1001

CMD ["python", "app.py"]
